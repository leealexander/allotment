@page
@model Allotment.Pages.WaterLevelSensorModel
@{
}

<h1 class="page-title">
    Water Level Sensor
    <span class="badge rounded-pill ms-2 fs-6 @(Model.IsWaterSensorOn ? "badge-health-good" : "badge-health-warn")">
        @(Model.IsWaterSensorOn ? "Sensor On" : "Sensor Off")
    </span>
</h1>

<div class="row g-3 mb-3">
    <div class="col-auto">
        <div class="dash-card text-center">
            <div class="dash-card-title mb-2">Current Level</div>
            <vc:water-level />
        </div>
    </div>
    <div class="col">
        <div class="chart-wrapper h-100">
            <div class="chart-header">
                <span class="chart-title">Pressure &amp; Height Over Time</span>
            </div>
            <canvas class="w-100" id="myChart"></canvas>
        </div>
    </div>
</div>

<div class="dash-card mt-2">
    <h2 class="chart-title mb-3">Calibration Readings</h2>
    <form asp-page-handler="SetKnownReadings" method="post">
        <div class="row">
            <div class="col-md-6">
                <textarea asp-for="KnownReadings" rows="12" spellcheck="false" class="form-control font-monospace" required></textarea>
            </div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary" name="Action" value="Save">Save readings</button>
        </div>
    </form>
</div>

@if (!Model.IsWaterSensorOn)
{
    <div class="dash-card mt-3">
        <h3 class="chart-title mb-3">Take a Known Reading</h3>
        <form method="post" asp-page-handler="TakeKnownReading">
            @Html.ValidationSummary()
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="KnownDepthCm" class="form-label">Known Depth (cm, optional)</label>
                    <input asp-for="KnownDepthCm" class="form-control" />
                    <span asp-validation-for="KnownDepthCm" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Annotation" class="form-label">Annotation (optional)</label>
                    <input asp-for="Annotation" class="form-control" />
                    <span asp-validation-for="Annotation" class="text-danger small"></span>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" value="Submit" class="btn btn-primary">Take a water level reading</button>
            </div>
        </form>
    </div>
}

@section scripts
{
    <script>
        const ctx = document.getElementById('myChart').getContext('2d');
        const myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: [@Model.GraphLabels],
                datasets: [{
                    label: 'Pressure (+@(Model.MinReading))',
                    borderColor: "#bae755",
                    backgroundColor: "rgba(186,231,85,0.08)",
                    data: [@Model.GraphPressureReadings],
                }, {
                    label: 'Height X 10',
                    borderColor: "#493f27",
                    backgroundColor: "rgba(73,63,39,0.08)",
                    data: [@Model.GraphHeightReadings],
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { labels: { color: '#1a2e1c', font: { size: 13 } } }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#c8dfc9' }, ticks: { color: '#5a7a5c' } },
                    x: { grid: { color: '#c8dfc9' }, ticks: { color: '#5a7a5c' } }
                }
            }
        });
    </script>
}
