@using Allotment.Pages.Shared.Components.WaterLevel.Models
@model WaterLevelViewModel;
@{
}

<div class="d-flex align-items-center gap-3 water-level-compact">
    <span class="fw-semibold text-nowrap" style="color: var(--color-brand-dark); font-size: 0.85rem;">
        Water Level &mdash; @Model.WaterLevelStatus
    </span>
    @if (Model.Percent != null)
    {
        <div class="progress flex-grow-1" style="height: 14px; border-radius: 8px; background: #c8dfc9;">
            <div class="progress-bar" role="progressbar"
                 style="width: @(Model.Percent)%; background: linear-gradient(to right, var(--color-water-dark), var(--color-water)); border-radius: 8px;"
                 aria-valuenow="@Model.Percent" aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>
    }
</div>

