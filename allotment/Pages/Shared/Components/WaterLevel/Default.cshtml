@using Allotment.Pages.Shared.Components.WaterLevel.Models
@model WaterLevelViewModel;
@{
}

<div class="water-level-compact">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="fw-semibold" style="color: var(--color-brand-dark); font-size: 0.85rem;">Water Level</span>
        <span style="color: var(--color-brand-dark); font-size: 0.85rem;">@Model.WaterLevelStatus</span>
    </div>
    @if (Model.Percent != null)
    {
        <div class="progress" style="height: 14px; border-radius: 8px; background: #c8dfc9;">
            <div class="progress-bar" role="progressbar"
                 style="width: @(Model.Percent)%; background: linear-gradient(to right, var(--color-water-dark), var(--color-water)); border-radius: 8px;"
                 aria-valuenow="@Model.Percent" aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>
    }
</div>

