        <div class="mt-3">
            <vc:water-level/>
        </div>
        <form class="mt-3 d-flex align-items-center" asp-page-handler="toggleAutoPilot" method="post">
            <input type="checkbox" asp-for="@Model.AutopilotEnabled" data-toggle="toggle" onChange="this.form.submit()" />
            <label asp-for="@Model.AutopilotEnabled" class="ms-2 fw-semibold" style="color: var(--color-brand-dark);">Autopilot</label>
        </form>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between mb-2">
    <h1 class="page-title mb-0">Polytunnel Control <small class="text-muted fw-normal fs-5">@Model.MachineTitle</small></h1>
    <button class="btn btn-sm d-md-none"
            style="background: var(--color-brand); color: #fff; border-radius: var(--radius-sm);"
            type="button" data-bs-toggle="offcanvas" data-bs-target="#controlsOffcanvas" aria-controls="controlsOffcanvas">
        &#9776; Controls
    </button>
</div>

<div class="row">
    <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-none d-md-block sidebar">
        <div class="position-sticky pt-3">
