@page
@model IndexModel
@{
    ViewData["Title"] = "Home page V4";
}

@* Mobile offcanvas controls drawer *@
<div class="offcanvas offcanvas-start" tabindex="-1" id="controlsOffcanvas" aria-labelledby="controlsOffcanvasLabel">
