    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <h2 class="chart-title mb-3" style="border-left:none; font-size:1.1rem;">Current Status</h2>
        <div class="status-metrics">
            <div class="dash-card dash-card--time">
                <div class="dash-card-title">Last reading</div>
                <div class="dash-card-value fs-6 fw-semibold" id="taken-at">waiting...</div>
            </div>
            <div class="dash-card dash-card--temp">
                <div class="dash-card-title">Temperature (°C)</div>
                <div class="dash-card-value" id="temp">—</div>
            </div>
            <div class="dash-card dash-card--battery">
                <div class="dash-card-title">Battery Charge</div>
                <div class="dash-card-value" id="battery-charge">—</div>
            </div>
            <div class="dash-card dash-card--solar">
                <div class="dash-card-title">Solar</div>
                <div class="dash-card-value" id="solar-watts">—</div>
            </div>
        </div>

        <div class="chart-wrapper">
            <div class="chart-header">
                <span class="chart-title">Historical — Temperature, Battery &amp; Solar</span>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary">Export</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="align-text-bottom" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        Today
                    </button>
                </div>
            </div>
            <canvas class="w-100" id="myChart"></canvas>
        </div>
    </main>
</div>

<div class="row mt-2">
    <div class="col-md-auto px-4">
        <span id="status" class="badge rounded-pill px-3 py-2" style="background-color: var(--color-brand); font-size: 0.9rem;">@Model.Status</span>
    </div>
</div>


@section scripts
    {
    <script>
        const ctx = document.getElementById('myChart').getContext('2d');
        const myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: [@Model.Labels],
                datasets: [{
                    label: 'Temp (°C)',
                    borderColor: "#bae755",
                    backgroundColor: "rgba(186,231,85,0.08)",
                    data: [@Model.TempByHour],
                    yAxisID: 'y',
                }, {
                    label: 'Battery (%)',
                    borderColor: "#9255e7",
                    backgroundColor: "rgba(146,85,231,0.08)",
                    data: [@Model.BatteryChargeByHour],
                    yAxisID: 'y',
                }, {
                    label: 'Solar (W)',
                    borderColor: "#e7a255",
                    backgroundColor: "rgba(231,162,85,0.08)",
                    data: [@Model.SolarWattsByHour],
                    yAxisID: 'y1',
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { labels: { color: '#1a2e1c', font: { size: 13 } } }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#c8dfc9' }, ticks: { color: '#5a7a5c' }, position: 'left' },
                    y1: { beginAtZero: true, grid: { drawOnChartArea: false }, ticks: { color: '#e7a255' }, position: 'right', title: { display: true, text: 'Solar (W)', color: '#e7a255' } },
                    x: { grid: { color: '#c8dfc9' }, ticks: { color: '#5a7a5c' } }
                }
            }
        });
    </script>

    <script>
        var pollTime = 3000;
        var errorTime = 1000;
        function setRunning(action, running) {
            document.querySelectorAll('[data-action="' + action + '"]').forEach(function(e) {
                if (running) e.classList.add("running");
                else e.classList.remove("running");
            });
        }

        function updateState() {
            fetch('/api/status')
                .then(response => {
                    if (!response.ok) {
                        window.setTimeout(updateState, errorTime);
                        var errorMessage = "Network error";
                        return {
                            takenAt: errorMessage,
                            temp: "Unknown",
                            batteryCharge: "—",
                            solarWatts: "—",
                            generalStatus: errorMessage,
                            doorsOpening: false,
                            doorsClosing: false,
                            waterOn: false
                        }
                    }
                    else {
                        window.setTimeout(updateState, pollTime)
                    }
                    return response.json()
                })
                .then(data => {
                    document.getElementById('taken-at').innerText = data.takenAt;
                    document.getElementById('temp').innerText = data.temp;
                    document.getElementById('battery-charge').innerText = data.batteryCharge;
                    document.getElementById('solar-watts').innerText = data.solarWatts;
                    document.getElementById('status').innerText = data.generalStatus;
                    setRunning('doors-open', data.doorsOpening);
                    setRunning('doors-close', data.doorsClosing);
                    setRunning('water-on', data.waterOn);
                });
        }
        window.setTimeout(updateState, 10)
    </script>
    }
