@page
@model Allotment.Pages.SettingsModel
@{
}

<h1 class="page-title">Settings</h1>

<form method="post">
    <div class="dash-card">
        <h2 class="chart-title mb-3">Configuration JSON</h2>
        <div class="row">
            <div class="col-md-8 col-lg-6">
                <textarea asp-for="Settings" rows="20" spellcheck="false" class="form-control font-monospace" required></textarea>
                <span asp-validation-for="Settings" class="text-danger small"></span>
            </div>
        </div>
        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary" name="Action" value="Save">Save changes</button>
            <button type="submit" class="btn btn-secondary" name="Action" value="Reset">Reset to defaults</button>
        </div>
    </div>
</form>

<div class="dash-card mt-3">
    <h2 class="chart-title mb-3">API Key</h2>
    <div class="row">
        <div class="col-md-8 col-lg-6">
            <textarea rows="3" spellcheck="false" class="form-control font-monospace" readonly>@(await Model.GenerateTokenAsync())</textarea>
        </div>
    </div>
</div>
