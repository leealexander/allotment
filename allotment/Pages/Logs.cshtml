@page
@model Allotment.Pages.LogModel
@{
}

<h1 class="page-title">Logs</h1>

<div class="dash-card d-flex align-items-center gap-3 py-2 mb-3">
    <span class="dash-card-title mb-0">Filter by date:</span>
    <form id="get-logs-form" method="Post" class="d-flex align-items-center gap-2">
        <input name="SelectedDate" value="@Model.SelectedDate.ToShortDateString()"
               id="selected-date" data-provide="datepicker"
               class="form-control form-control-sm" style="width: auto;" />
        <button id="get-logs-button" class="btn btn-sm btn-primary">Select date</button>
    </form>
</div>

<div class="dash-card p-0 overflow-hidden">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th scope="col">Date</th>
                <th scope="col">Message</th>
                <th scope="col">Area</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var e in Model.Logs)
            {
                <tr>
                    <td>@(e.EventDateUtc.HasValue ? e.EventDateUtc.Value.ToLocalTime() : "NULL")</td>
                    <td>@e.Message</td>
                    <td>@e.Area</td>
                </tr>
            }
        </tbody>
    </table>
</div>


@section scripts
{
    <script>
        var control = $('#selected-date');
        control.datepicker({
            todayBtn: true,
            todayHighlight: true,
            autoclose: true,
        });
        control.on('changeDate', function (ev) {
            $('#get-logs-form').submit();
        });
        $(document).ready(function () {
            $('#get-logs-button').hide();
        });
    </script>
}
